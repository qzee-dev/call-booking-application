{
  "name": "user-api",
  "projectType": "application",
  "root": "apps/user-api",
  "sourceRoot": "apps/user-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "apps/user-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm test",
        "cwd": "apps/user-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/user-api"
      }
    },
    "sonar": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sonar-scanner",
        "cwd": "apps/user-api"
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t ${DOCKERHUB_USERNAME}/user-api:${TAG} .",
        "cwd": "apps/user-api"
      }
    },
    "docker:push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push ${DOCKERHUB_USERNAME}/user-api:${TAG}",
        "cwd": "apps/user-api"
      }
    }
  }
}