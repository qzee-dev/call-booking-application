{
  "name": "admin-api",
  "projectType": "application",
  "root": "apps/admin-api",
  "sourceRoot": "apps/admin-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "apps/admin-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm test",
        "cwd": "apps/admin-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/admin-api"
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t myorg/admin-api:${TAG} .",
        "cwd": "apps/admin-api"
      }
    },
    "docker:push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push myorg/admin-api:${TAG}",
        "cwd": "apps/admin-api"
      }
    }
  }
}
