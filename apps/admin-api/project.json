{
  "name": "admin-api",
  "projectType": "application",
  "sourceRoot": "apps/admin-api/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/admin-api"
      }
    },

    "test": {
      "executor": "nx:run-commands",
      "outputs": ["coverage/apps/admin-api"],
      "options": {
        "command": "npm test -- --coverage",
        "cwd": "apps/admin-api"
      }
    },

    "build": {
      "executor": "nx:run-commands",
      "outputs": ["dist/apps/admin-api"],
      "options": {
        "command": "npm run build",
        "cwd": "apps/admin-api"
      }
    },

    "docker-build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "docker build -t alqoseemi/admin-api:${TAG:-latest} -f Dockerfile .",
        "cwd": "apps/admin-api"
      }
    },

    "docker-push": {
      "executor": "nx:run-commands",
      "dependsOn": ["docker-build"],
      "options": {
        "command": "docker push alqoseemi/admin-api:${TAG:-latest}"
      }
    }
  },
  "tags": []
}
